# ─────────────────────────────────────────────────────────────────────────────
# RAG Financial Data Assistant — environment variables
# Copy to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Google Cloud ──────────────────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_SA_KEY_PATH=./secrets/gcp-sa.json   # local path mounted into containers
BQ_DATASET=marts                        # BigQuery dataset holding dbt mart tables

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=your-rag-financial-data-bucket

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost     # use 'chromadb' when running inside Docker Compose
CHROMA_PORT=8000

# ── RAG tuning ────────────────────────────────────────────────────────────────
RETRIEVAL_K=6             # number of documents retrieved per query
LLM_TEMPERATURE=0.1       # lower = more deterministic financial answers

# ── Airflow (if running locally) ──────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
AIRFLOW__CORE__LOAD_EXAMPLES=False
